{
  "name": "connectmoda-backend",
  "version": "2.0.0",
  "description": "Backend API para ConnectModa – Plataforma para talleres de ropa colombianos",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "worker": "node worker.js",
    "test": "jest --runInBand --detectOpenHandles",
    "test:unit": "jest tests/__tests__/unit --runInBand",
    "test:integration": "jest tests/__tests__/integration --runInBand",
    "test:e2e": "jest tests/__tests__/e2e --runInBand",
    "test:coverage": "jest --coverage --runInBand --detectOpenHandles",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "stripe:listen": "stripe listen --forward-to localhost:3000/api/webhooks/stripe"
  },
  "jest": {
    "testEnvironment": "node",
    "globalSetup": "./tests/__tests__/setup.js",
    "testMatch": [
      "**/tests/__tests__/**/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 75,
        "lines": 80,
        "statements": 80
      }
    },
    "collectCoverageFrom": [
      "controllers/**/*.js",
      "middleware/**/*.js",
      "models/**/*.js",
      "utils/**/*.js",
      "services/**/*.js",
      "!**/node_modules/**"
    ]
  },
  "dependencies": {
    "@sentry/node": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.16.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-validator": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.1",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.13",
    "pdfkit": "^0.15.0",
    "prom-client": "^15.1.3",
    "redis": "^4.6.14",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "nodemon": "^3.1.3"
  },
  "optionalDependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@bull-board/api": "^5.21.5",
    "@bull-board/express": "^5.21.5",
    "cloudinary": "^2.3.0",
    "sharp": "^0.33.4"
  },
  "notes": {
    "redis_tls": "REDIS_TLS=true para Upstash/Railway con TLS",
    "queues_off": "QUEUE_ENABLED=false para ejecutar jobs inline sin Redis",
    "wompi": "Wompi usa fetch nativo de Node 18 — no necesita SDK adicional"
  }
}