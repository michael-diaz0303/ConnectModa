# ══════════════════════════════════════════════
#  ConnectModa — Variables de Entorno
#  Copia este archivo como .env y rellena los valores
# ══════════════════════════════════════════════

# ── Servidor ──────────────────────────────────
NODE_ENV=development
FRONTEND_URL=http://localhost:5500
PORT=3000
API_VERSION=v1

# ── Base de datos ─────────────────────────────
MONGO_URI=mongodb://localhost:27017/connectmoda
# Para Replica Set (producción):
# MONGO_URI=mongodb://mongo1:27017,mongo2:27017,mongo3:27017/connectmoda?replicaSet=rs0

# ── Autenticación JWT ──────────────────────────
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_seguro
JWT_EXPIRES=7d
JWT_REFRESH_EXPIRES=30d

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://localhost:6379
BULL_REDIS_URL=redis://localhost:6379
# Para Upstash / Railway con TLS:
# REDIS_URL=rediss://:password@host:6380
# REDIS_TLS=true

# ── Colas (Bull) ──────────────────────────────
QUEUE_ENABLED=true
# QUEUE_ENABLED=false  → jobs se ejecutan inline sin Redis

# ── RabbitMQ ──────────────────────────────────
RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# ── Wompi (pasarela de pagos colombiana) ─────
# Obtén tus llaves en: https://comercios.wompi.co
WOMPI_ENV=sandbox
WOMPI_PUBLIC_KEY=pub_test_...
WOMPI_PRIVATE_KEY=prv_test_...
WOMPI_EVENTS_SECRET=

# ── Storage (imágenes) ────────────────────────
# Opciones: s3 | cloudinary | local
STORAGE_PROVIDER=local

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET_NAME=connectmoda-media
CDN_URL=

# Cloudinary (25 GB gratis/mes — alternativa a S3)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Email (Nodemailer) ────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu@email.com
SMTP_PASS=app_password_aqui
EMAIL_FROM=ConnectModa <no-reply@connectmoda.co>

# ── IA ────────────────────────────────────────
# Proveedor activo: openai | anthropic | gemini | ollama
IA_PROVIDER=openai
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=
OLLAMA_URL=http://localhost:11434

# ── Sentry (monitoreo de errores) ─────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Prometheus / Métricas ─────────────────────
METRICS_ENABLED=true
METRICS_PORT=9090

# ── CORS ──────────────────────────────────────
CORS_ORIGIN=http://localhost:5500,http://localhost:3001

# ── Rate Limiting ─────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
