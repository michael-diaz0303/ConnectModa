{
  "title": "ConnectModa — API Overview",
  "uid": "connectmoda-api",
  "tags": ["connectmoda", "api", "production"],
  "timezone": "America/Bogota",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "🟢 Disponibilidad (SLO 99.5%)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "100 - (sum(rate(http_requests_total{job='connectmoda-api',status=~'5..'}[5m])) / sum(rate(http_requests_total{job='connectmoda-api'}[5m])) * 100)",
        "legendFormat": "Disponibilidad %"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 99 },
              { "color": "green", "value": 99.5 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "⚡ Latencia p95 (SLO < 500ms)",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job='connectmoda-api'}[5m])) by (le)) * 1000",
        "legendFormat": "p95 ms"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 300 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "🚀 Requests/seg",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "sum(rate(http_requests_total{job='connectmoda-api'}[1m]))",
        "legendFormat": "req/s"
      }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 4,
      "title": "❌ Errores 5xx/min",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "sum(rate(http_requests_total{job='connectmoda-api',status=~'5..'}[1m])) * 60",
        "legendFormat": "errores/min"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "📦 Órdenes creadas (últimas 24h)",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "increase(connectmoda_orders_created_total[24h])",
        "legendFormat": "órdenes"
      }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 6,
      "title": "💳 Pagos procesados (últimas 24h)",
      "type": "stat",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "increase(connectmoda_payments_total[24h])",
        "legendFormat": "pagos"
      }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 7,
      "title": "📈 Requests por ruta (req/min)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "expr": "sum by (route) (rate(http_requests_total{job='connectmoda-api'}[1m])) * 60",
        "legendFormat": "{{ route }}"
      }],
      "fieldConfig": { "defaults": { "unit": "reqpm" } }
    },
    {
      "id": 8,
      "title": "⏱️ Latencia por ruta (p50/p95/p99)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, route) (rate(http_request_duration_seconds_bucket{job='connectmoda-api'}[5m]))) * 1000",
          "legendFormat": "p50 {{ route }}"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, route) (rate(http_request_duration_seconds_bucket{job='connectmoda-api'}[5m]))) * 1000",
          "legendFormat": "p95 {{ route }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 9,
      "title": "🗄️ MongoDB — Operaciones/seg",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 8, "h": 6 },
      "targets": [{
        "expr": "rate(mongodb_op_counters_total[1m])",
        "legendFormat": "{{ type }}"
      }],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 10,
      "title": "⚡ Redis — Hit Rate",
      "type": "stat",
      "gridPos": { "x": 8, "y": 12, "w": 4, "h": 6 },
      "targets": [{
        "expr": "rate(redis_keyspace_hits_total[5m]) / (rate(redis_keyspace_hits_total[5m]) + rate(redis_keyspace_misses_total[5m])) * 100",
        "legendFormat": "Hit rate %"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 70 },
              { "color": "green", "value": 85 }
            ]
          }
        }
      }
    },
    {
      "id": 11,
      "title": "🐇 RabbitMQ — Mensajes en cola",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 6 },
      "targets": [{
        "expr": "rabbitmq_queue_messages",
        "legendFormat": "{{ queue }}"
      }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 12,
      "title": "🖥️ CPU por instancia (%)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 18, "w": 12, "h": 6 },
      "targets": [{
        "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode='idle'}[5m])) * 100)",
        "legendFormat": "{{ instance }}"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      }
    },
    {
      "id": 13,
      "title": "💾 RAM por instancia (%)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 18, "w": 12, "h": 6 },
      "targets": [{
        "expr": "(node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / node_memory_MemTotal_bytes * 100",
        "legendFormat": "{{ instance }}"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    }
  ]
}
